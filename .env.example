NODE_ENV=development
PORT=3000

# App bootstrap (GET /v1/app/config)
APP_MIN_SUPPORTED_VERSION=1.0.0
FEATURE_GUEST_MODE=false
FEATURE_CHAT_ENABLED=true
FEATURE_RECOMMENDATIONS_ENABLED=true

# Database (Phase 1+)
DATABASE_URL=postgresql://heritage:heritage@localhost:5432/heritage_hub?schema=public
REDIS_URL=redis://localhost:6379

# JWT (Phase 2+)
JWT_ACCESS_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRES=15m

# AI service (Phase 6 — Pattern A FastAPI proxy)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=dev-ai-key-change-me
AI_SERVICE_TIMEOUT_MS=5000
AI_SERVICE_USE_STUB=true
